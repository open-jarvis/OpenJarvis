# OpenJarvis notification settings — copy to ".env" and fill in real values.
#
#   cp .env.example .env      # then edit .env
#
# SECURITY:
#   - ".env" is git-ignored. NEVER commit real secrets. This example file
#     must only ever contain placeholders.
#   - Real values are read from the environment. ".env" is just a convenience
#     loader for local runs; existing environment variables always take
#     precedence over the file.
#   - For Gmail/Outlook, use an APP PASSWORD (not your login password) and keep
#     2FA enabled on the account.

# ---------------------------------------------------------------------------
# Email alerts (SMTP)  -> send_email_alert(subject, message)
# ---------------------------------------------------------------------------
EMAIL_FROM=alerts@example.com
EMAIL_TO=you@example.com
SMTP_HOST=smtp.gmail.com
# 587 = STARTTLS (default), 465 = implicit TLS/SSL
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=your-app-password-here

# ---------------------------------------------------------------------------
# Text message alerts (Twilio)  -> send_sms_alert(message)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# The Twilio number messages are sent FROM (E.164 format, e.g. +15551234567)
TWILIO_FROM_NUMBER=+15550000000
# Your personal number messages are sent TO (E.164 format)
MY_PHONE_NUMBER=+15551234567

# ---------------------------------------------------------------------------
# Push notifications  -> send_push_alert(title, message)
# ntfy is preferred (no account needed). Install the ntfy app and subscribe to
# your topic. Choose a long, unguessable topic name (it acts like a password).
# ---------------------------------------------------------------------------
NTFY_TOPIC=openjarvis-CHANGE-ME-to-something-random
# Optional: self-hosted server (defaults to https://ntfy.sh)
# NTFY_SERVER=https://ntfy.sh
# Optional: access token if your ntfy server requires auth
# NTFY_TOKEN=

# Optional Pushover fallback (used only when NTFY_TOPIC is unset)
# PUSHOVER_TOKEN=
# PUSHOVER_USER=
