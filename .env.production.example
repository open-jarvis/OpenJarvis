.env.production.example

# Application Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://openjarvis:openjarvis@postgres:5432/openjarvis
POSTGRES_USER=openjarvis
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=openjarvis

# MongoDB Configuration
MONGODB_URL=mongodb://openjarvis:change-me@mongodb:27017/openjarvis
MONGODB_USER=openjarvis
MONGODB_PASSWORD=change-me-in-production

# Redis Configuration
REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me-in-production

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me-in-production

# Security
SECRET_KEY=generate-a-secure-random-key-here
JWT_SECRET=generate-a-secure-random-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker

# CORS Settings
CORS_ORIGINS=["https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["Content-Type", "Authorization"]

# OAuth/External Services
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GOOGLE_API_KEY=your-google-key-here

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
JAEGER_HOST=localhost
JAEGER_PORT=6831

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@example.com

# File Storage
STORAGE_BACKEND=s3
S3_BUCKET=openjarvis-prod
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Cache Configuration
CACHE_BACKEND=redis
CACHE_TTL=3600

# Logging
LOG_FORMAT=json
LOG_FILE=/var/log/openjarvis/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# Performance
MAX_WORKERS=8
TIMEOUT=30
KEEPALIVE_TIMEOUT=5

# Feature Flags
ENABLE_AGENTS=true
ENABLE_TOOLS=true
ENABLE_SKILLS=true
ENABLE_MINING=false

# Deployment
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=admin@yourdomain.com
