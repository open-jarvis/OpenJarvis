{
  "buildCommand": "uv sync --extra server && uv run pip install -e .",
  "outputDirectory": ".",
  "framework": "fastapi",
  "python": {
    "version": "3.12"
  },
  "functions": {
    "src/openjarvis/server/app.py": {
      "runtime": "python3.12",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/openjarvis/server/app.py"
    }
  ],
  "env": {
    "PYTHONPATH": "src"
  }
}
